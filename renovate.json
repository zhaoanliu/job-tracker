{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 9am on monday"],
  "rebaseWhen": "behind-base-branch",
  "minimumReleaseAge": "7 days",
  "prConcurrentLimit": 3,
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "minimumReleaseAge": "0 days",
    "labels": ["security"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.yml$"],
      "matchStrings": [
        "supabase/setup-cli@[^\\n]+\\n\\s+with:\\n\\s+version: (?<currentValue>[\\d.]+)"
      ],
      "depNameTemplate": "supabase/cli",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.yml$"],
      "matchStrings": [
        "npm install -g @anthropic-ai/claude-code@(?<currentValue>[\\d.]+)"
      ],
      "depNameTemplate": "@anthropic-ai/claude-code",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "matchFileNames": [".github/workflows/**"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "workflow tool versions",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "matchFileNames": [".github/workflows/**"],
      "matchUpdateTypes": ["major"],
      "groupName": "workflow tool versions (major)"
    },
    {
      "groupName": "React ecosystem",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"]
    },
    {
      "groupName": "ESLint ecosystem",
      "matchPackageNames": ["eslint", "@eslint/**"]
    },
    {
      "groupName": "Next.js ecosystem",
      "matchPackageNames": ["next", "eslint-config-next"]
    },
    {
      "groupName": "Tailwind ecosystem",
      "matchPackageNames": ["tailwindcss", "@tailwindcss/**", "autoprefixer", "postcss"]
    },
    {
      "groupName": "Sentry",
      "matchPackageNames": ["@sentry/**"]
    }
  ]
}
