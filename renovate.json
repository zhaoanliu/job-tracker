{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["every weekend"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.yml$"],
      "matchStrings": [
        "supabase/setup-cli@[^\\n]+\\n\\s+with:\\n\\s+version: (?<currentValue>[\\d.]+)"
      ],
      "depNameTemplate": "supabase/cli",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.yml$"],
      "matchStrings": [
        "npm install -g @anthropic-ai/claude-code@(?<currentValue>[\\d.]+)"
      ],
      "depNameTemplate": "@anthropic-ai/claude-code",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [".github/workflows/**"],
      "groupName": "workflow tool versions",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ]
}
