NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Testmail.app — used by auth.email.spec.ts; tests are skipped when not set
TESTMAIL_API_KEY=your-testmail-api-key
TESTMAIL_NAMESPACE=your-testmail-namespace

# Sentry — project slug is "javascript-nextjs" (auto-named by Sentry), NOT the repo name
# SENTRY_AUTH_TOKEN needs project:releases scope for source map uploads during build
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=your-sentry-auth-token
